{
  "name": "@jinglonglong/springkg-installer",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && npm run copy-assets && node ../springkg-shared/scripts/fix-esm-extensions.mjs dist",
    "copy-assets": "node -e \"const fs=require('fs'),path=require('path');fs.mkdirSync('dist/db',{recursive:true});fs.copyFileSync('src/db/schema.sql','dist/db/springkg-schema.sql')\""
  },
  "dependencies": {
    "@jinglonglong/springkg-shared": "0.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jinglonglong/springgraph.git"
  },
  "bugs": {
    "url": "https://github.com/jinglonglong/springgraph/issues"
  },
  "homepage": "https://jinglonglong.github.io/springgraph/"
}
