---
import '@fontsource-variable/archivo';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '@fontsource/ibm-plex-mono/600.css';
import '../styles/theme.css';
import GraphDiagram from '../components/GraphDiagram.astro';
import { getStarsLabel } from '../lib/github';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const repo = 'https://github.com/jinglonglong/springgraph';
const npm = 'https://www.npmjs.com/package/@jinglonglong/springgraph';
const stars = await getStarsLabel();
const install = 'npm install -g @jinglonglong/springgraph';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link class="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
		<title>springgraph — 为 Spring Cloud 打造的语义图谱与 AI 协同引擎</title>
		<meta
			name="description"
			content="基于 Tree-sitter 的本地化代码智能工具。将微服务、HTTP 端点、Spring Bean 依赖及 MyBatis SQL 链路解析为图谱，让 AI Agent 提问效率提升 10 倍。"
		/>
		<meta property="og:title" content="springgraph" />
		<meta property="og:description" content="为 Spring Cloud 打造的语义图谱与 AI 协同引擎。" />
		<meta property="og:type" content="website" />
		<meta name="theme-color" content="#f7f6f2" />
	</head>
	<body>
		<div class="frame">
			<header class="nav">
				<a class="wordmark" href={`${base}/`}>springgraph</a>
				<nav class="nav-links">
					<a href={`${base}/getting-started/introduction`}>文档</a>
					<a class="opt" href={`${base}/reference/languages`}>支持语言</a>
					<a href={repo}>GitHub</a>
					<a class="star" href={`${repo}/stargazers`}>
						<span class="star-glyph" aria-hidden="true">★</span>{stars}
					</a>
				</nav>
			</header>

			<main>
				<section class="hero">
					<div class="hero-left">
						<h1>为 Spring Boot / Spring Cloud 打造的语义图谱与 AI 协同引擎</h1>
						<p class="lede">
							基于 Tree-sitter 的本地化代码智能工具。将微服务、HTTP 端点、Spring Bean 依赖及 MyBatis SQL 链路解析为知识图谱，让 AI Agent (Claude Code/Cursor) 的代码分析效率提升 10 倍。
						</p>
						<div class="cta">
							<a class="btn btn-primary" href={`${base}/getting-started/quickstart`}>快速开始</a>
							<a class="btn btn-ghost" href={`${base}/getting-started/introduction`}>查看文档</a>
						</div>
						<div class="install" data-install={install}>
							<code>{install}</code>
							<button class="copy" type="button" aria-label="Copy install command">
								<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6">
									<rect x="9" y="9" width="11" height="11" />
									<path d="M5 15V5a1 1 0 0 1 1-1h9" />
								</svg>
							</button>
						</div>
					</div>
					<div class="hero-right">
						<GraphDiagram />
					</div>
				</section>

				<!-- 截图与效果展示 -->
				<section class="showcase">
					<div class="showcase-container">
						<div class="showcase-card">
							<div class="window-header">
								<span class="dot red"></span>
								<span class="dot yellow"></span>
								<span class="dot green"></span>
								<span class="window-title">终端演示 — springgraph serve --mcp</span>
							</div>
							<div class="window-body terminal-body">
								<div class="line prompt">springgraph serve --mcp --path ./springcloud-demo</div>
								<div class="line info">[springgraph] 正在初始化数据库连接...</div>
								<div class="line info">[springgraph] 已成功加载 springkg.db (Spring 专属语义层)</div>
								<div class="line info">[springgraph] MCP 本地服务器已在 stdio 管道就绪</div>
								<div class="line success">[mcp] 成功注册 4 个 Spring Cloud 专属微服务分析工具:</div>
								<div class="line tool">- spring_find_entry (按 URL/控制器/Feign名定位流量入口)</div>
								<div class="line tool">- spring_trace_flow (全链路追踪: Endpoint -> Service -> Mapper -> SQL)</div>
								<div class="line tool">- spring_assets_overview (系统服务画像与敏感配置总览)</div>
								<div class="line tool">- spring_method_impact (分析方法变更的事务、SQL 与异常影响面)</div>
								<div class="line prompt highlight">AI Agent 提问: "帮我分析 GET /api/users/&#123;id&#125; 的调用链"</div>
								<div class="line result">=== 调用链分析结果 (Trace Flow) ===</div>
								<div class="line result">1. [入口] UserController.getUser (UserController.java:24)</div>
								<div class="line result">2. [业务] UserService.getUserById (UserService.java:12)</div>
								<div class="line result">3. [数据] UserMapper.selectById (UserMapper.java:8)</div>
								<div class="line result">4. [SQL] select * from users where id = #&#123;id&#125; (UserMapper.xml:4)</div>
							</div>
						</div>

						<div class="showcase-card">
							<div class="window-header">
								<span class="dot red"></span>
								<span class="dot yellow"></span>
								<span class="dot green"></span>
								<span class="window-title">Web UI — 架构依赖可视化浏览器 (springgraph web)</span>
							</div>
							<div class="window-body webui-body">
								<div class="webui-sidebar">
									<div class="sidebar-item active">架构剖面图</div>
									<div class="sidebar-item">HTTP 端点列表</div>
									<div class="sidebar-item">Feign 客户端</div>
									<div class="sidebar-item">SQL 依赖树</div>
								</div>
								<div class="webui-canvas">
									<div class="canvas-node entry" style="top: 30px; left: 140px;">
										<span class="node-badge">Entry (入口层)</span>
										<span class="node-name">UserController</span>
									</div>
									<div class="canvas-node remote" style="top: 115px; left: 20px;">
										<span class="node-badge">Remote (远程层)</span>
										<span class="node-name">OrderClient</span>
									</div>
									<div class="canvas-node business" style="top: 115px; left: 250px;">
										<span class="node-badge">Business (业务层)</span>
										<span class="node-name">UserService</span>
									</div>
									<div class="canvas-node data" style="top: 205px; left: 250px;">
										<span class="node-badge">Data (数据层)</span>
										<span class="node-name">UserMapper</span>
									</div>
									<svg class="canvas-lines" style="position: absolute; width: 100%; height: 100%; top: 0; left: 0; pointer-events: none;">
										<path d="M 195 65 L 105 115" stroke="var(--cg-rule)" stroke-width="1.5" fill="none" />
										<path d="M 195 65 L 285 115" stroke="var(--cg-rule)" stroke-width="1.5" fill="none" />
										<path d="M 285 150 L 285 205" stroke="var(--cg-rule)" stroke-width="1.5" fill="none" />
									</svg>
								</div>
							</div>
						</div>
					</div>
				</section>

				<section class="features">
					<article class="feature">
						<svg class="ficon" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5">
							<rect x="19" y="4" width="10" height="10" />
							<rect x="4" y="34" width="10" height="10" />
							<rect x="19" y="34" width="10" height="10" />
							<rect x="34" y="34" width="10" height="10" />
							<path d="M24 14v10M9 34v-10h30v10M24 24v10" />
						</svg>
						<h2>Spring 语义知识图谱</h2>
						<p>
							深入解析 Spring Boot / Spring Cloud 特有注解，连接微服务网关、REST 端点、Service 业务层、Feign 远程调用及 MyBatis SQL，形成完整闭环。
						</p>
					</article>
					<article class="feature">
						<svg class="ficon" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5">
							<rect x="5" y="10" width="38" height="28" />
							<path d="M13 20l6 4-6 4M26 28h9" />
						</svg>
						<h2>精简高效的 MCP 工具</h2>
						<p>
							提供 4 个 Spring 专属工具，让 AI 过滤无用代码干扰，直奔端点逻辑、全链路追踪、事务与异常分析，提问响应速度及准确率大幅上升。
						</p>
					</article>
					<article class="feature">
						<svg class="ficon" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5">
							<circle cx="16" cy="24" r="10" />
							<circle cx="16" cy="24" r="3.5" fill="currentColor" stroke="none" />
							<path d="M16 8v6M16 34v6M2 24h4M26 24h6M32 24l8-6M32 24l8 6" />
							<circle cx="41" cy="17" r="2.5" />
							<circle cx="41" cy="31" r="2.5" />
						</svg>
						<h2>架构剖面与可视化 Web UI</h2>
						<p>
							自动把类划分为 6 层与 15 个架构角色（Controller, Mapper 等），并提供图形化的 Web 浏览器，让项目关系与依赖流一目了然。
						</p>
					</article>
				</section>
			</main>

			<footer class="foot">
				<span class="foot-mark">springgraph</span>
				<nav class="foot-links">
					<a href={`${base}/getting-started/introduction`}>文档</a>
					<a href={repo}>GitHub</a>
					<a href={npm}>npm</a>
					<a href={`${repo}/blob/master/LICENSE`}>许可证</a>
				</nav>
			</footer>
		</div>

		<script>
			const wrap = document.querySelector('.install');
			const btn = wrap?.querySelector('.copy');
			if (wrap && btn) {
				const original = btn.innerHTML;
				btn.addEventListener('click', async () => {
					try {
						await navigator.clipboard.writeText(wrap.getAttribute('data-install') || '');
						btn.innerHTML = '<span class="copied">Copied</span>';
						setTimeout(() => (btn.innerHTML = original), 1400);
					} catch {
						/* clipboard blocked — no-op */
					}
				});
			}
		</script>

		<style>
			:global(html) {
				background: var(--cg-paper);
			}
			:global(body) {
				margin: 0;
				font-family: var(--sl-font);
				color: var(--cg-ink);
				overflow-x: hidden;
			}

			.frame {
				max-width: 1440px;
				margin: 0 auto;
				border: 1px solid var(--cg-rule);
			}

			/* ---- nav ---- */
			.nav {
				display: flex;
				align-items: center;
				justify-content: space-between;
				padding: 1.1rem 2rem;
				border-bottom: 1px solid var(--cg-rule);
			}
			.wordmark {
				font-weight: 800;
				font-size: 1.4rem;
				letter-spacing: -0.035em;
				color: var(--cg-ink);
				text-decoration: none;
			}
			.nav-links {
				display: flex;
				align-items: center;
				gap: 2rem;
			}
			.nav-links a {
				color: var(--cg-ink);
				text-decoration: none;
				font-size: 0.98rem;
			}
			.nav-links a:not(.star):hover {
				text-decoration: underline;
				text-underline-offset: 4px;
			}
			.star {
				display: inline-flex;
				align-items: center;
				gap: 0.4rem;
				border: 1px solid var(--cg-rule);
				padding: 0.4rem 0.85rem;
				font-variant-numeric: tabular-nums;
			}
			.star:hover {
				background: var(--cg-paper-press);
			}
			.star-glyph {
				font-size: 0.85em;
			}

			/* ---- hero ---- */
			.hero {
				display: grid;
				grid-template-columns: 1.05fr 0.95fr;
				border-bottom: 1px solid var(--cg-rule);
			}
			.hero-left {
				padding: 4.5rem 3rem 4rem;
				min-width: 0; /* allow the grid cell to shrink below content width */
			}
			.hero-right {
				border-inline-start: 1px solid var(--cg-rule);
				display: flex;
				align-items: center;
				justify-content: center;
				padding: 2.5rem;
				min-width: 0; /* let the SVG scale down instead of widening the page */
			}
			h1 {
				font-size: clamp(2.4rem, 6vw, 4.6rem);
				line-height: 0.98;
				font-weight: 800;
				letter-spacing: -0.04em;
				margin: 0 0 1.6rem;
				overflow-wrap: break-word;
			}
			.lede {
				font-size: 1.18rem;
				line-height: 1.5;
				color: var(--cg-ink-2);
				max-width: 34ch;
				margin: 0 0 2.2rem;
			}
			.cta {
				display: flex;
				gap: 0.9rem;
				margin-bottom: 1.6rem;
				flex-wrap: wrap;
			}
			.btn {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				padding: 0.8rem 1.5rem;
				font-size: 1rem;
				font-weight: 600;
				text-decoration: none;
				border: 1px solid var(--cg-rule);
				transition:
					background 0.12s ease,
					color 0.12s ease;
			}
			.btn-primary {
				background: var(--cg-ink);
				color: var(--cg-paper);
			}
			.btn-primary:hover {
				background: transparent;
				color: var(--cg-ink);
			}
			.btn-ghost {
				background: transparent;
				color: var(--cg-ink);
			}
			.btn-ghost:hover {
				background: var(--cg-paper-press);
			}
			.install {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				border: 1px solid var(--cg-rule);
				padding: 0.5rem 0.55rem 0.5rem 0.9rem;
				font-family: var(--sl-font-mono);
				font-size: 0.95rem;
			}
			.install code {
				font-family: inherit;
				background: none;
				color: var(--cg-ink);
			}
			.copy {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				border: none;
				background: transparent;
				cursor: pointer;
				padding: 0.3rem;
				color: var(--cg-ink-2);
			}
			.copy:hover {
				color: var(--cg-ink);
			}
			.copy :global(.copied) {
				font-family: var(--sl-font);
				font-size: 0.8rem;
				padding: 0 0.2rem;
			}

			/* ---- features ---- */
			.features {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
			}
			.feature {
				display: grid;
				grid-template-columns: auto 1px 1fr;
				column-gap: 1.5rem;
				align-items: center;
				padding: 2.6rem 2rem;
			}
			.feature + .feature {
				border-inline-start: 1px solid var(--cg-rule);
			}
			/* full-height vertical divider between the icon and the text */
			.feature::before {
				content: '';
				grid-column: 2;
				grid-row: 1 / 3;
				align-self: stretch;
				width: 1px;
				background: var(--cg-rule);
			}
			.ficon {
				grid-column: 1;
				grid-row: 1 / 3;
				align-self: center;
				width: 64px;
				height: 64px;
				color: var(--cg-ink);
			}
			.feature h2 {
				grid-column: 3;
				grid-row: 1;
				font-size: 1.3rem;
				font-weight: 700;
				margin: 0 0 0.6rem;
			}
			.feature p {
				grid-column: 3;
				grid-row: 2;
				font-size: 1rem;
				line-height: 1.55;
				color: var(--cg-ink-2);
				margin: 0;
				max-width: 34ch;
			}

			/* ---- footer ---- */
			.foot {
				display: flex;
				align-items: center;
				justify-content: space-between;
				padding: 1.4rem 2rem;
				border-top: 1px solid var(--cg-rule);
			}
			.foot-mark {
				font-weight: 800;
				letter-spacing: -0.03em;
			}
			.foot-links {
				display: flex;
				gap: 1.6rem;
			}
			.foot-links a {
				color: var(--cg-ink-2);
				text-decoration: none;
				font-size: 0.92rem;
			}
			.foot-links a:hover {
				color: var(--cg-ink);
				text-decoration: underline;
				text-underline-offset: 3px;
			}

			/* ---- restrained entrance ---- */
			@media (prefers-reduced-motion: no-preference) {
				.hero-left > * {
					opacity: 0;
					transform: translateY(8px);
					animation: cg-in 0.5s ease forwards;
				}
				.hero-left > *:nth-child(1) {
					animation-delay: 0.04s;
				}
				.hero-left > *:nth-child(2) {
					animation-delay: 0.1s;
				}
				.hero-left > *:nth-child(3) {
					animation-delay: 0.16s;
				}
				.hero-left > *:nth-child(4) {
					animation-delay: 0.22s;
				}
				@keyframes cg-in {
					to {
						opacity: 1;
						transform: none;
					}
				}
			}

			/* ---- responsive ---- */
			@media (max-width: 860px) {
				.hero {
					grid-template-columns: 1fr;
				}
				.hero-right {
					border-inline-start: none;
					border-top: 1px solid var(--cg-rule);
				}
				.features {
					grid-template-columns: 1fr;
				}
				.feature + .feature {
					border-inline-start: none;
					border-top: 1px solid var(--cg-rule);
				}
				.feature {
					column-gap: 1rem;
					padding: 2rem 1.25rem;
				}
				.ficon {
					width: 48px;
					height: 48px;
				}
				.nav {
					padding: 1rem 1.25rem;
				}
				.nav-links {
					gap: 0.85rem;
					font-size: 0.85rem;
				}
				.nav-links .opt {
					display: none;
				}
				.star {
					display: none; /* count still lives on the GitHub page */
				}
				.hero-left {
					padding: 2.75rem 1.25rem 2.5rem;
				}
				.foot {
					flex-direction: column;
					gap: 1rem;
					align-items: flex-start;
				}
			}

			/* ---- showcase ---- */
			.showcase {
				padding: 3rem 2rem;
				border-bottom: 1px solid var(--cg-rule);
				background: var(--cg-paper-2);
			}
			.showcase-container {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 2rem;
			}
			@media (max-width: 860px) {
				.showcase-container {
					grid-template-columns: 1fr;
				}
			}
			.showcase-card {
				border: 1px solid var(--cg-rule);
				background: var(--cg-paper);
				display: flex;
				flex-direction: column;
				min-height: 320px;
			}
			.window-header {
				display: flex;
				align-items: center;
				padding: 0.6rem 1rem;
				border-bottom: 1px solid var(--cg-rule);
				background: var(--cg-paper-press);
				gap: 0.4rem;
			}
			.dot {
				width: 10px;
				height: 10px;
				border: 1px solid var(--cg-rule);
				display: inline-block;
			}
			.dot.red { background: #ff5f56; }
			.dot.yellow { background: #ffbd2e; }
			.dot.green { background: #27c93f; }
			.window-title {
				margin-left: 0.5rem;
				font-size: 0.85rem;
				font-family: var(--sl-font-mono);
				font-weight: 600;
				color: var(--cg-ink-2);
			}
			.window-body {
				padding: 1.2rem;
				flex-grow: 1;
				font-size: 0.85rem;
				line-height: 1.5;
				overflow: auto;
			}
			.terminal-body {
				background: #1e1c16;
				color: #f3f1ea;
				font-family: var(--sl-font-mono);
			}
			:global(html[data-theme='dark']) .terminal-body {
				background: #12110c;
			}
			.terminal-body .line {
				margin-bottom: 0.3rem;
				white-space: pre-wrap;
			}
			.terminal-body .prompt::before {
				content: "$ ";
				color: #87847a;
			}
			.terminal-body .info {
				color: #b4b1a5;
			}
			.terminal-body .success {
				color: #a3e635;
			}
			.terminal-body .tool {
				padding-left: 1rem;
				color: #38bdf8;
			}
			.terminal-body .result {
				color: #fb923c;
			}
			.terminal-body .highlight {
				color: #facc15;
				font-weight: bold;
				margin-top: 0.8rem;
			}

			/* Web UI Mockup */
			.webui-body {
				display: grid;
				grid-template-columns: 130px 1fr;
				padding: 0;
				min-height: 260px;
			}
			.webui-sidebar {
				border-right: 1px solid var(--cg-rule);
				background: var(--cg-paper-2);
				display: flex;
				flex-direction: column;
			}
			.sidebar-item {
				padding: 0.6rem 0.8rem;
				font-size: 0.75rem;
				border-bottom: 1px solid var(--cg-rule-soft);
				cursor: pointer;
				font-weight: 500;
				color: var(--cg-ink-2);
			}
			.sidebar-item.active {
				background: var(--cg-paper-press);
				font-weight: bold;
