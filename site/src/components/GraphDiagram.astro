---
// Flat technical node-link diagram for the hero. Hand-placed so it reads as a
// deliberate blueprint, not a physics blob: thin ink lines, hollow nodes, mono
// labels. Hovering a node inks it in. No glow, no gradients, no motion.
---

<svg
	class="cg-graph"
	viewBox="0 0 780 600"
	role="img"
	aria-label="A code knowledge graph showing a Spring Boot request flow: UserController.java links to OrderClient.java and UserService.java, which further connect to order-service, UserMapper.java, application.yml, user_mapper.xml, and the users database table."
>
	<g class="edges">
		<!-- UserController -> OrderClient -->
		<line x1="390" y1="80" x2="210" y2="220" />
		<!-- UserController -> UserService -->
		<line x1="390" y1="80" x2="410" y2="260" />
		<!-- OrderClient -> order-service -->
		<line x1="210" y1="220" x2="150" y2="400" />
		<!-- UserService -> UserMapper -->
		<line x1="410" y1="260" x2="610" y2="220" />
		<!-- UserMapper -> user_mapper.xml -->
		<line x1="610" y1="220" x2="530" y2="400" />
		<!-- user_mapper.xml -> users (table) -->
		<line x1="530" y1="400" x2="680" y2="420" />
		<!-- application.yml -> UserService -->
		<line x1="320" y1="420" x2="410" y2="260" />
	</g>

	<g class="nodes">
		<g class="node">
			<circle cx="390" cy="80" r="9" />
			<text x="408" y="85" text-anchor="start">UserController.java</text>
		</g>
		<g class="node">
			<circle cx="210" cy="220" r="9" />
			<text x="192" y="225" text-anchor="end">OrderClient.java</text>
		</g>
		<g class="node">
			<circle cx="410" cy="260" r="9" />
			<text x="428" y="265" text-anchor="start">UserService.java</text>
		</g>
		<g class="node">
			<circle cx="610" cy="220" r="9" />
			<text x="628" y="225" text-anchor="start">UserMapper.java</text>
		</g>
		<g class="node">
			<circle cx="150" cy="400" r="9" />
			<text x="150" y="430" text-anchor="middle">order-service</text>
		</g>
		<g class="node">
			<circle cx="530" cy="400" r="9" />
			<text x="530" y="430" text-anchor="middle">user_mapper.xml</text>
		</g>
		<g class="node">
			<circle cx="680" cy="420" r="9" />
			<text x="680" y="450" text-anchor="middle">users (table)</text>
		</g>
		<g class="node">
			<circle cx="320" cy="420" r="9" />
			<text x="320" y="450" text-anchor="middle">application.yml</text>
		</g>
	</g>
</svg>

<style>
	.cg-graph {
		width: 100%;
		height: auto;
		max-width: 560px;
		min-width: 0; /* flex item: allow shrinking below intrinsic SVG width */
		display: block;
	}
	.cg-graph .edges line {
		stroke: var(--cg-ink);
		stroke-width: 1.25;
	}
	.cg-graph .node circle {
		fill: var(--cg-paper);
		stroke: var(--cg-ink);
		stroke-width: 1.5;
		transition: fill 0.12s ease;
	}
	.cg-graph .node text {
		font-family: var(--sl-font-mono);
		font-size: 15px;
		fill: var(--cg-ink);
		dominant-baseline: middle;
	}
	.cg-graph .node:hover circle {
		fill: var(--cg-ink);
	}
</style>
